{"docstore/metadata": {"5f3471b5-c31e-4df4-8a6f-db018a396596": {"doc_hash": "230543d2d323b5e6b98fee1c1dd6734eb9138dbfaca92075961b5190a0b21efd"}, "2e14c1d4-d89c-4142-b7f2-899b53aec5d5": {"doc_hash": "dfaa90b9f1d0497f2836e7a73b6e332125ba378ff023382491970708da76b0d5"}, "f3f4a926-77d2-47ee-a2ef-30861ef478e6": {"doc_hash": "c71ccc82b01671d056efc305f652935f90a9c62c5cbf2f5cfbda32fa82588363", "ref_doc_id": "5f3471b5-c31e-4df4-8a6f-db018a396596"}, "5bc231e9-1f32-4129-adae-f4b56590b391": {"doc_hash": "e6a4588707d58d032864096ce52ab93853a407e60e1cf10580dbd80d8dcd2a65", "ref_doc_id": "2e14c1d4-d89c-4142-b7f2-899b53aec5d5"}}, "docstore/data": {"f3f4a926-77d2-47ee-a2ef-30861ef478e6": {"__data__": {"id_": "f3f4a926-77d2-47ee-a2ef-30861ef478e6", "embedding": null, "metadata": {"page_label": "1", "file_name": "Sample.pdf", "file_path": "C:\\Users\\Shreyas\\GenAI_RAG\\Data\\Sample.pdf", "file_type": "application/pdf", "file_size": 77663, "creation_date": "2025-02-02", "last_modified_date": "2025-02-01"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "5f3471b5-c31e-4df4-8a6f-db018a396596", "node_type": "4", "metadata": {"page_label": "1", "file_name": "Sample.pdf", "file_path": "C:\\Users\\Shreyas\\GenAI_RAG\\Data\\Sample.pdf", "file_type": "application/pdf", "file_size": 77663, "creation_date": "2025-02-02", "last_modified_date": "2025-02-01"}, "hash": "230543d2d323b5e6b98fee1c1dd6734eb9138dbfaca92075961b5190a0b21efd", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Design thinking is a user-centered, iterative problem-solving \nmethodology that focuses on understanding users\u2019 needs \nand finding innovative solutions. It involves several stages, \neach aimed at refining ideas through collaboration and \nfeedback. The five primary stages of design thinking are: \n1. Empathize: Understand the user\u2019s needs, desires, and \nchallenges. This stage involves research, observations, \nand interviews with the target audience to gather \ninsights. \n2. Define: Clearly articulate the problem based on the \ninsights gained in the empathize stage. This step helps \nin framing the challenge in a way that is actionable and \nuser-centric. \n3. Ideate: Generate a wide range of ideas and potential \nsolutions. Brainstorming, sketching, and other creative \ntechniques are used to come up with multiple \napproaches. \n4. Prototype: Create simple, low-cost prototypes or \nmodels to represent the solutions. Prototypes help \nvisualize ideas and serve as tools for testing and \nrefinement. \n5. Test: Evaluate the prototypes with users to gather \nfeedback. This stage is iterative and may lead to \nrevisiting earlier stages for improvement. \nDesign thinking encourages flexibility and collaboration, \nmaking it an effective approach for tackling complex, \nambiguous problems across various industries.", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 1311, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "5bc231e9-1f32-4129-adae-f4b56590b391": {"__data__": {"id_": "5bc231e9-1f32-4129-adae-f4b56590b391", "embedding": null, "metadata": {"page_label": "2", "file_name": "Sample.pdf", "file_path": "C:\\Users\\Shreyas\\GenAI_RAG\\Data\\Sample.pdf", "file_type": "application/pdf", "file_size": 77663, "creation_date": "2025-02-02", "last_modified_date": "2025-02-01"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "2e14c